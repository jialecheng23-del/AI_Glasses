  EVT_CAP_OK=21, EVT_AI_START=22, EVT_AI_OK=23, EVT_IMG_START=24, EVT_IMG_OK=25,
  EVT_REC=26, EVT_SPEAK=27, EVT_WAKE=28, EVT_AUDIO_CONN=30, EVT_AUDIO_END=31,
  ERR_WIFI=50, ERR_CAM=51, ERR_OOM=52, ERR_HTTP=53, ERR_JSON=54, ERR_BUSY=55
};
