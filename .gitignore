#define WAKE_WINDOWS        6     // 需连续响约0.2秒才触发（比一声脆响长，比半个词短）
#define WAKE_COOLDOWN_MS    1500  // 播完声音后的冷却(ms)
#define WAKE_PRE_MS         900   // 预录时长(ms)：一直保留最近这么久的声音，保证"小智同学"整句被录进去
#define WAKE_POST_MS        2800  // 触发后最长继续录(ms)——"小智同学+短问题"一口气说完也装得下
#define WAKE_SILENCE_MS     600   // 说完停顿这么久就提前结束抓音、立刻送识别（不傻等）
// ====================================================

