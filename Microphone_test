// 识图：JPEG图片 -> Base64 -> 千帆VL模型 -> 文字描述 -> 发手机+语音播报
void analyzeImage(const uint8_t* jpg, size_t len) {
  if (wifiState != WIFI_READY) { sendEvent(ERR_WIFI, "not ready"); return; }
  sendEvent(EVT_AI_START, "");
  String prefix = String("{\"model\":\"") + g_vlmodel +
    "\",\"messages\":[{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":\"" + g_prompt +
    "\"},{\"type\":\"image_url\",\"image_url\":{\"url\":\"data:image/jpeg;base64,";
  String suffix = "\"}}]}]}";
  size_t b64len = 4 * ((len + 2) / 3);
  char* body = (char*)ps_malloc(prefix.length() + b64len + suffix.length() + 1);
  if (!body) { sendEvent(ERR_OOM, "body"); return; }
  memcpy(body, prefix.c_str(), prefix.length());
  size_t olen = 0;
  mbedtls_base64_encode((unsigned char*)(body + prefix.length()), b64len + 1, &olen, jpg, len);
  memcpy(body + prefix.length() + olen, suffix.c_str(), suffix.length());
  size_t bodyLen = prefix.length() + olen + suffix.length();
  WiFiClientSecure client; client.setInsecure();
  HTTPClient https; https.setTimeout(30000);
  https.useHTTP10(true);   // 强制HTTP/1.0：禁止chunked分块回应（ESP32解析分块会读出空body）
  if (!https.begin(client, g_apiurl)) { free(body); sendEvent(ERR_HTTP, "begin"); return; }
  https.addHeader("Content-Type", "application/json");
  https.addHeader("Authorization", String("Bearer ") + g_apikey);
  int code = https.POST((uint8_t*)body, bodyLen);
  if (code < 0) {   // 网络失败重试一次
    Serial.printf("[vl] 请求失败(%d)，重试一次\n", code);
    https.end(); vTaskDelay(pdMS_TO_TICKS(300));
    if (!https.begin(client, g_apiurl)) { free(body); sendEvent(ERR_HTTP, "begin"); return; }
    https.addHeader("Content-Type", "application/json");
    https.addHeader("Authorization", String("Bearer ") + g_apikey);
    code = https.POST((uint8_t*)body, bodyLen);
  }
  free(body);
  if (code == 200) {
    String resp = https.getString();
    resp.trim();   // 掐掉生成期间的心跳空行
    Serial.printf("[vl] 回应%d字节\n", resp.length());
    StaticJsonDocument<128> filter; filter["choices"][0]["message"]["content"] = true;
    DynamicJsonDocument doc(6144);
    if (resp.length() && !deserializeJson(doc, resp, DeserializationOption::Filter(filter))) {
      const char* content = doc["choices"][0]["message"]["content"] | "";
      sendEvent(EVT_AI_OK, ""); sendAIAnswer(content); ttsSpeak(content);
    } else { Serial.printf("[vl] 返回=%s\n", resp.substring(0, 200).c_str()); sendEvent(ERR_JSON, "vl"); }
  } else {
    String err = https.getString();   // 报错时打印服务器原话
    Serial.printf("[vl] http=%d 返回=%s\n", code, err.substring(0, 300).c_str());
    sendEvent(ERR_HTTP, String(code).c_str());
  }
  https.end();
}
// 取当前日期时间字符串（NTP对时成功后才有效；还没对上时返回空串）
String nowString() {
  struct tm t;
  if (!getLocalTime(&t, 50)) return "";
  char buf[64];
  const char* wd[] = {"日","一","二","三","四","五","六"};
  snprintf(buf, sizeof(buf), "%d年%d月%d日星期%s %02d:%02d",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday, wd[t.tm_wday], t.tm_hour, t.tm_min);
  return String(buf);
}
// 文字聊天：用户问题 -> DeepSeek -> 返回回答文字（失败返回空串）
String llmChat(const String& userText) {
  if (wifiState != WIFI_READY) { sendEvent(ERR_WIFI, "not ready"); return ""; }
  DynamicJsonDocument doc(4096);
  doc["model"] = g_chatmodel;
  doc["max_tokens"] = 200;   // 限制回答长度：生成更快，语音播报也不会截太多
  JsonArray msgs = doc.createNestedArray("messages");
  JsonObject sys = msgs.createNestedObject();
  sys["role"] = "system";
  // 把真实时间喂给AI（AI自己没有时钟，不喂就只能瞎编时间）
  String sysmsg = "你是一个智能眼镜语音助手，用简短、口语化的中文回答，不要用markdown，不要太长。不确定的信息直接说不知道，绝对不要编造。";
  String ts = nowString();
  if (ts.length()) sysmsg += String("现在的准确时间：") + ts + "。";
  sys["content"] = sysmsg;
  JsonObject u = msgs.createNestedObject();
  u["role"] = "user"; u["content"] = userText;
  String body; serializeJson(doc, body);

  // 聊天用独立配置(chaturl/chatkey=DeepSeek)，没配则跟随主配置
  String curl = g_chaturl.length() ? g_chaturl : g_apiurl;
  String ckey = g_chatkey.length() ? g_chatkey : g_apikey;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient https; https.setTimeout(30000);
  https.useHTTP10(true);   // 强制HTTP/1.0：禁止chunked分块回应（DeepSeek必需，否则读出空body）
  if (!https.begin(client, curl)) { sendEvent(ERR_HTTP, "begin"); return ""; }
  https.addHeader("Content-Type", "application/json");
  https.addHeader("Authorization", String("Bearer ") + ckey);
  int code = https.POST(body);
  if (code < 0) {   // 网络失败重试一次
    Serial.printf("[chat] 请求失败(%d)，重试一次\n", code);
    https.end(); vTaskDelay(pdMS_TO_TICKS(300));
    if (!https.begin(client, curl)) { sendEvent(ERR_HTTP, "begin"); return ""; }
    https.addHeader("Content-Type", "application/json");
    https.addHeader("Authorization", String("Bearer ") + ckey);
    code = https.POST(body);
  }
  String ans = "";
  if (code == 200) {
    String resp = https.getString();
    resp.trim();   // 掐掉DeepSeek生成期间发的心跳空行
    Serial.printf("[chat] 回应%d字节\n", resp.length());
    StaticJsonDocument<128> filter; filter["choices"][0]["message"]["content"] = true;
    DynamicJsonDocument rd(6144);
    if (resp.length() && !deserializeJson(rd, resp, DeserializationOption::Filter(filter)))
      ans = rd["choices"][0]["message"]["content"] | "";
    else { Serial.printf("[chat] 返回=%s\n", resp.substring(0, 200).c_str()); sendEvent(ERR_JSON, "chat"); }
  } else {
    String err = https.getString();   // 报错时打印服务器原话
    Serial.printf("[chat] http=%d 返回=%s\n", code, err.substring(0, 300).c_str());
    sendEvent(ERR_HTTP, String(code).c_str());
  }
  https.end();
  return ans;
}

// ====================== WiFi 音频串流播放（手机连8000端口推PCM）======================
void streamClient(WiFiClient& client) {
  uint8_t rbuf[1024]; int fill = 0;
  uint32_t rate = AUDIO_SAMPLE_RATE;
  uint32_t t0 = millis();
  while (fill < 8 && millis() - t0 < 800) {
    int n = client.read(rbuf + fill, 8 - fill);
    if (n > 0) fill += n; else vTaskDelay(pdMS_TO_TICKS(2));
    if (!client.connected() && client.available() == 0) break;
  }
  if (fill >= 8 && memcmp(rbuf, "AUD1", 4) == 0) {
    rate = (uint32_t)rbuf[4] | ((uint32_t)rbuf[5]<<8) | ((uint32_t)rbuf[6]<<16) | ((uint32_t)rbuf[7]<<24);
    if (rate < 8000 || rate > 48000) rate = AUDIO_SAMPLE_RATE;
    fill = 0;
  }
  i2s_set_sample_rates(SPK_I2S_PORT, rate);
  i2s_zero_dma_buffer(SPK_I2S_PORT);
  uint32_t idle = millis();
  for (;;) {
    int n = client.read(rbuf + fill, sizeof(rbuf) - fill);
    if (n > 0) { fill += n; idle = millis(); }
    else { if (!client.connected() && client.available() == 0) break;
           if (millis() - idle > 8000) break;
           vTaskDelay(pdMS_TO_TICKS(2)); }
    int usable = fill - (fill & 1);
    if (usable >= 2) {
      if (g_volume != 100) { int16_t* sp = (int16_t*)rbuf; for (int i = 0; i < usable/2; i++) sp[i] = (int16_t)((int32_t)sp[i]*g_volume/100); }
      size_t w; i2s_write(SPK_I2S_PORT, rbuf, usable, &w, portMAX_DELAY);
      int rest = fill - usable; if (rest) rbuf[0] = rbuf[usable]; fill = rest;
    }
  }
}

void audioTask(void*) {
  bool srvUp = false;
  for (;;) {
    if (wifiState == WIFI_READY && !srvUp) { audioServer.begin(); srvUp = true; Serial.printf("Audio server :%d\n", AUDIO_PORT); }
    if (!srvUp) { vTaskDelay(pdMS_TO_TICKS(300)); continue; }
    WiFiClient client = audioServer.available();
    if (client) {
      client.setNoDelay(true);
      g_audioPlaying = true; sendEvent(EVT_AUDIO_CONN, "");
      streamClient(client);
      client.stop(); i2s_zero_dma_buffer(SPK_I2S_PORT);
      g_audioPlaying = false; sendEvent(EVT_AUDIO_END, "");
    } else vTaskDelay(pdMS_TO_TICKS(20));
  }
}

// ====================== 本地提示音 ======================

// 生成 freq Hz 正弦波，播 ms 毫秒，跟随音量
void playTone(int freq, int ms) {
  i2s_set_sample_rates(SPK_I2S_PORT, 16000);
  i2s_start(SPK_I2S_PORT);
  const int N = 256;
  int16_t buf[N];
  float phase = 0, step = 2.0f * PI * freq / 16000.0f;
  int amp = 9000 * g_volume / 100;
  long total = 16L * ms, done = 0;
  while (done < total) {
    int cnt = (total - done < N) ? (total - done) : N;
    for (int i = 0; i < cnt; i++) { buf[i] = (int16_t)(sinf(phase) * amp); phase += step; if (phase > 2*PI) phase -= 2*PI; }
    size_t w; i2s_write(SPK_I2S_PORT, buf, cnt * 2, &w, portMAX_DELAY);
    done += cnt;
  }
}

// 本地测试音：880Hz 响1秒，验证喇叭硬件
void playBeep() {
  Serial.printf("[beep] 880Hz 1秒, vol=%d\n", g_volume);
  i2s_set_sample_rates(SPK_I2S_PORT, 16000);
  i2s_start(SPK_I2S_PORT);
  i2s_zero_dma_buffer(SPK_I2S_PORT);
  const int N = 256;
  int16_t buf[N];
  float phase = 0, step = 2.0f * PI * 880 / 16000.0f;
  long total = 16000, done = 0; long written = 0; esp_err_t ret = ESP_OK;
  while (done < total) {
    int cnt = (total - done < N) ? (total - done) : N;
    for (int i = 0; i < cnt; i++) { buf[i] = (int16_t)(sinf(phase) * 9000); phase += step; if (phase > 2*PI) phase -= 2*PI; }
    size_t w; ret = i2s_write(SPK_I2S_PORT, buf, cnt * 2, &w, portMAX_DELAY);
    written += w; done += cnt;
  }
  Serial.printf("[beep] 完成 ret=%d 写入=%ld字节\n", (int)ret, written);
}

// ====================== 语音对话完整流程 ======================
// 高音"叮"=开始录音 -> 录4秒 -> 低音"咚"=录音结束 -> 百度识别 -> DeepSeek回答 -> 播报
void doVoiceChat() {
  uint8_t* pcm; size_t len;
  playTone(1200, 80);   // 高音"叮"：开始录音，请说话
  sendEvent(EVT_REC, String(RECORD_SECONDS).c_str());
  if (!recordMic(&pcm, &len, RECORD_SECONDS)) { sendEvent(ERR_OOM, "rec"); return; }
  playTone(700, 120);   // 低音"咚"：录音结束，正在识别
  int16_t* sp16 = (int16_t*)pcm; int mpeak = 0;
  for (size_t i = 0; i < len / 2; i++) { int a = sp16[i] < 0 ? -sp16[i] : sp16[i]; if (a > mpeak) mpeak = a; }
  Serial.printf("[mic] 录了 %u 字节, 最大振幅=%d\n", (unsigned)len, mpeak);
  String q = asrRecognize(pcm, len);
  free(pcm);
  if (!q.length()) { notifyText("ASR>(没听清)"); ttsSpeak("没听清，请再说一遍"); return; }
  notifyText("ASR>" + q);
  String ans = llmChat(q);
  if (ans.length()) { sendAIAnswer(ans.c_str()); ttsSpeak(ans); }
  else ttsSpeak("网络不太好，请再问一次");   // AI没回话也要给用户语音反馈
}

// ====================== 工作任务：逐个执行队列里的命令 ======================
void workerTask(void*) {
  cmd_t c;
  for (;;) {
    if (xQueueReceive(cmdQueue, &c, portMAX_DELAY) != pdPASS) continue;
    String text = c.text ? String(c.text) : "";
    if (c.text) free(c.text);
    if (g_busy) { sendEvent(ERR_BUSY, ""); continue; }
    g_busy = true;

    switch (c.cmd) {
      case CMD_PHOTO:
      case CMD_SHOT: {
        if (!initCamera()) { sendEvent(ERR_CAM, ""); break; }
        camera_fb_t* fb = esp_camera_fb_get();
        if (!fb) { sendEvent(ERR_CAM, "grab"); break; }
        size_t len = fb->len; sendEvent(EVT_CAP_OK, String(len).c_str());
        if (c.cmd == CMD_SHOT) { sendImage(fb->buf, len); esp_camera_fb_return(fb); }
        else {
          uint8_t* buf = (uint8_t*)ps_malloc(len);
          if (!buf) { esp_camera_fb_return(fb); sendEvent(ERR_OOM, "copy"); break; }
          memcpy(buf, fb->buf, len); esp_camera_fb_return(fb);
          analyzeImage(buf, len); free(buf);
        }
        break;
      }
      case CMD_ASK: {
        notifyText("Q>" + text);
        String ans = llmChat(text);
        if (ans.length()) { sendAIAnswer(ans.c_str()); ttsSpeak(ans); }
        break;
      }
      case CMD_SAY:    ttsSpeak(text); break;
      case CMD_LISTEN: doVoiceChat();  break;
      case CMD_BEEP:   playBeep();     break;
    }
    g_busy = false;
  }
}

// ====================== LED / 按键 ======================

inline void ledWrite(bool on) {
#if LED_ACTIVE_LOW
  digitalWrite(LED_PIN, on ? LOW : HIGH);
#else
  digitalWrite(LED_PIN, on ? HIGH : LOW);
#endif
}

// LED: 忙=快闪  播音频=常亮  蓝牙已连=2秒闪一下  未连=1秒慢闪
void updateLed() {
  uint32_t t = millis(); bool on;
  if (g_busy)               on = (t % 200) < 100;
  else if (g_audioPlaying)  on = true;
  else if (deviceConnected) on = (t % 2000) < 60;
  else                      on = (t % 1000) < 500;
  ledWrite(on);
}

// BOOT按键: 长按1秒=语音对话  短按=拍照识图
void pollButton() {
  static bool prev = true; static uint32_t downT = 0;
  bool b = digitalRead(BOOT_BTN);
  if (prev && !b) downT = millis();
  if (!prev && b) {
    uint32_t held = millis() - downT;
    if (held > 1000) enqueueCmd(CMD_LISTEN, "");
    else if (held > 30) enqueueCmd(CMD_PHOTO, "");
  }
  prev = b;
}

