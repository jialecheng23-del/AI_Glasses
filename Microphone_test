// URL 编码（百度TTS的文本参数要求）
String urlEncode(const String& s) {
  String o; const char* hex = "0123456789ABCDEF";
  for (size_t i = 0; i < s.length(); i++) {
    uint8_t c = (uint8_t)s[i];
    if ((c>='0'&&c<='9')||(c>='A'&&c<='Z')||(c>='a'&&c<='z')) o += (char)c;
    else { o += '%'; o += hex[c >> 4]; o += hex[c & 0xF]; }
  }
  return o;
}

// 按字节数截断字符串，但不把一个 UTF-8 中文字切成两半
String utf8Cap(const String& s, int maxBytes) {
  if ((int)s.length() <= maxBytes) return s;
  int cut = maxBytes;
  while (cut > 0 && ((uint8_t)s[cut] & 0xC0) == 0x80) cut--;
  return s.substring(0, cut);
}

