// ====================== ② 板载 PDM 麦克风 ======================
// 麦克风有两个使用方：wakeTask 平时占着监听音量，recordMic 录音时借用。
// 用 g_micWanted / g_micHeld 两个标志交接，保证同一时刻只有一方在读 I2S0。

// 安装麦克风 I2S 驱动（PDM 接收模式）
bool micDriverInstall() {
  i2s_config_t c = {};
  c.mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX | I2S_MODE_PDM);
  c.sample_rate = AUDIO_SAMPLE_RATE;
  c.bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT;
  c.channel_format = I2S_CHANNEL_FMT_ONLY_LEFT;
  c.communication_format = I2S_COMM_FORMAT_STAND_I2S;
  c.intr_alloc_flags = ESP_INTR_FLAG_LEVEL1;
  c.dma_buf_count = 8; c.dma_buf_len = 256;
  if (i2s_driver_install(MIC_I2S_PORT, &c, 0, NULL) != ESP_OK) return false;
  i2s_pin_config_t p = {};
  p.bck_io_num = I2S_PIN_NO_CHANGE;                   // PDM 没有位时钟
  p.ws_io_num = MIC_PDM_CLK;                          // PDM模式下 ws 脚复用为 PDM 时钟
  p.data_out_num = I2S_PIN_NO_CHANGE; p.data_in_num = MIC_PDM_DATA;
  i2s_set_pin(MIC_I2S_PORT, &p);
  return true;
}

// 录 seconds 秒音频，输出 16bit 16kHz 单声道 PCM，调用方用完要 free()
bool recordMic(uint8_t** out, size_t* outLen, int seconds) {
  // 先请 wakeTask 让出麦克风（最多等1秒）
  g_micWanted = true;
  uint32_t tw = millis();
  while (g_micHeld && millis() - tw < 1000) vTaskDelay(pdMS_TO_TICKS(10));

  size_t samples = (size_t)AUDIO_SAMPLE_RATE * seconds;
  size_t bytes = samples * 2;
  int16_t* pcm = (int16_t*)ps_malloc(bytes);
  if (!pcm) pcm = (int16_t*)malloc(bytes);
  if (!pcm) { g_micWanted = false; return false; }
  if (!micDriverInstall()) { free(pcm); g_micWanted = false; return false; }

  int16_t tmp[512]; size_t br;
  for (int i = 0; i < 6; i++) i2s_read(MIC_I2S_PORT, tmp, sizeof(tmp), &br, pdMS_TO_TICKS(200)); // 丢掉开头杂音
  size_t got = 0;
  while (got < samples) {
    if (i2s_read(MIC_I2S_PORT, tmp, sizeof(tmp), &br, pdMS_TO_TICKS(500)) != ESP_OK) break;
    int n = br / 2;
    for (int i = 0; i < n && got < samples; i++) {
      int32_t s = (int32_t)tmp[i] * MIC_GAIN;
      if (s > 32767) s = 32767; if (s < -32768) s = -32768;
      pcm[got++] = (int16_t)s;
    }
  }
  i2s_driver_uninstall(MIC_I2S_PORT);   // 用完卸载，把麦克风还给 wakeTask
  g_micWanted = false;
  if (got == 0) { free(pcm); return false; }
  *out = (uint8_t*)pcm; *outLen = got * 2;
  return true;
}

// ---------- 语音唤醒任务：常开麦克风监听音量 ----------
// 连续几个窗口音量超阈值 -> 触发语音对话。调灵敏度: wakelvl 命令
void wakeTask(void*) {
  int hot = 0;
  uint32_t quietT = millis();
  static int16_t tmp[512]; size_t br;   // static放静态区，不占任务栈
  for (;;) {
    // 不该监听的时候：放掉麦克风闲置
    if (!g_wakeEnabled || g_micWanted || g_busy || g_audioPlaying) {
      if (g_micHeld) { i2s_driver_uninstall(MIC_I2S_PORT); g_micHeld = false; }
      hot = 0; quietT = millis();
      vTaskDelay(pdMS_TO_TICKS(50)); continue;
    }
    // 刚忙完先冷却，防止喇叭的声音把自己吵醒
    if (millis() - quietT < WAKE_COOLDOWN_MS) { vTaskDelay(pdMS_TO_TICKS(50)); continue; }
    // 需要时接管麦克风
    if (!g_micHeld) {
      if (!micDriverInstall()) { vTaskDelay(pdMS_TO_TICKS(1000)); continue; }
      g_micHeld = true; hot = 0;
      for (int i = 0; i < 6; i++) i2s_read(MIC_I2S_PORT, tmp, sizeof(tmp), &br, pdMS_TO_TICKS(200));
    }
    // 读一个窗口，算平均振幅当作响度
    if (i2s_read(MIC_I2S_PORT, tmp, sizeof(tmp), &br, pdMS_TO_TICKS(200)) != ESP_OK || br == 0) continue;
    int n = br / 2; long sum = 0;
    for (int i = 0; i < n; i++) { int a = tmp[i] < 0 ? -tmp[i] : tmp[i]; sum += a; }
    int avg = (int)(sum / n);
    if (avg > g_wakeThresh) hot++; else hot = 0;
    if (hot >= WAKE_WINDOWS) {      // 连续约100ms都很响 => 有人在说话
      hot = 0;
      i2s_driver_uninstall(MIC_I2S_PORT); g_micHeld = false;
      Serial.printf("[wake] 语音唤醒! 响度=%d (阈值%d)\n", avg, g_wakeThresh);
      sendEvent(EVT_WAKE, String(avg).c_str());
      enqueueCmd(CMD_LISTEN, "");
      quietT = millis();
    }
  }
}

