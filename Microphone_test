// ====================== WiFi 状态机（loop 每秒调一次，断线自动重连）======================
void updateWiFi() {
  if (wifiNeedReconnect) { wifiNeedReconnect = false; WiFi.disconnect(); wifiState = WIFI_IDLE; }
  switch (wifiState) {
    case WIFI_IDLE:
      Serial.printf("[wifi] 正在连: %s\n", g_ssid.c_str());
      WiFi.begin(g_ssid.c_str(), g_pass.c_str());
      wifiState = WIFI_CONNECTING; wifiRetry = 0; break;
    case WIFI_CONNECTING:
      if (WiFi.status() == WL_CONNECTED) {
        wifiState = WIFI_READY; sendEvent(EVT_WIFI_OK, WiFi.localIP().toString().c_str());
        configTime(8 * 3600, 0, "ntp.aliyun.com", "cn.pool.ntp.org");   // 联网后NTP对时(东八区)
      }
    case WIFI_READY:
      if (WiFi.status() != WL_CONNECTED) wifiState = WIFI_IDLE; break;
  }
}

